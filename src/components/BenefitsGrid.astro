---
import type { LandingVariant } from "../data/landing";
import { variants } from "../data/landing";

type Props = {
  variant: LandingVariant;
};

const { variant } = Astro.props;
const content = variants[variant];
---

<section id="beneficios" class="section-anchor bg-page py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-primary">Benefícios</p>
      <h2 class="mt-4 text-balance font-display text-3xl font-black tracking-[-0.04em] text-ink sm:text-5xl">
        O resultado aparece no ar que circula e no cuidado com o aparelho.
      </h2>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {content.benefits.map((benefit) => (
        <article class="rounded-[2rem] border border-border bg-panel p-7 shadow-lift">
          <h3 class="font-display text-2xl font-black tracking-tight text-ink">{benefit.title}</h3>
          <p class="mt-4 text-base font-medium leading-7 text-muted">{benefit.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
