---
import { contact } from "../data/landing";

const steps = [
  {
    title: "Mande uma foto",
    description: "Mostre o aparelho e conte o que está acontecendo: não gela, pinga, cheira mal ou está sujo.",
  },
  {
    title: "Receba orientação",
    description: "A conversa já direciona o tipo de atendimento e reduz ida e volta antes de marcar.",
  },
  {
    title: "Agende a limpeza",
    description: "A equipe vai até o local e faz a limpeza sem precisar retirar o split da parede.",
  },
];
---

<section id="processo" class="section-anchor bg-accent px-4 py-16 text-slate-950 sm:px-6 lg:px-8" aria-labelledby="popular-flow-title">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.2em] text-slate-800">Caminho mais rápido</p>
        <h2 id="popular-flow-title" class="mt-4 text-balance font-display text-4xl font-black tracking-[-0.05em] sm:text-6xl">
          Orçamento sem enrolação, direto pelo WhatsApp.
        </h2>
        <a
          href={contact.whatsappHref}
          class="mt-8 inline-flex rounded-full bg-slate-950 px-8 py-5 text-lg font-black text-white shadow-lift transition-colors duration-200 hover:bg-slate-800 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-slate-950"
        >
          Pedir orçamento agora
        </a>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {steps.map((step, index) => (
          <article class="rounded-[2rem] bg-white/74 p-6 shadow-lift">
            <span class="grid size-12 place-items-center rounded-2xl bg-slate-950 font-display text-xl font-black text-white">
              {index + 1}
            </span>
            <h3 class="mt-8 font-display text-2xl font-black tracking-tight">{step.title}</h3>
            <p class="mt-3 text-sm font-bold leading-6 text-slate-700">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
