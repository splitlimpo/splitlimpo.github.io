---
import type { LandingVariant } from "../data/landing";
import { variants } from "../data/landing";

type Props = {
  variant: LandingVariant;
};

const { variant } = Astro.props;
const content = variants[variant];
---

<section aria-label="Diferenciais da Split Limpo" class="border-y border-border bg-panel/48">
  <div class="mx-auto grid max-w-7xl gap-4 px-4 py-6 sm:px-6 md:grid-cols-3 lg:px-8">
    {content.trust.map((item) => (
      <article class="rounded-3xl border border-border bg-page/56 p-5 shadow-lift">
        <h2 class="font-display text-lg font-black tracking-tight text-ink">{item.title}</h2>
        <p class="mt-2 text-sm font-medium leading-6 text-muted">{item.description}</p>
      </article>
    ))}
  </div>
</section>
