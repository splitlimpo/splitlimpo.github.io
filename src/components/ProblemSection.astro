---
import { shared } from "../data/landing";
---

<section id="problemas" class="section-anchor bg-page py-20 sm:py-24">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.86fr_1.14fr] lg:px-8">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-primary">Sinais de manutenção</p>
      <h2 class="mt-4 max-w-xl text-balance font-display text-3xl font-black tracking-[-0.04em] text-ink sm:text-5xl">
        Quando o split pede limpeza, ele avisa no conforto e na conta.
      </h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {shared.pains.map((pain) => (
        <article class="group rounded-[2rem] border border-border bg-panel p-6 shadow-lift transition-transform duration-200 hover:-translate-y-1">
          <div class="mb-7 grid size-12 place-items-center rounded-2xl bg-primary/16 text-primary">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-black tracking-tight text-ink">{pain}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
