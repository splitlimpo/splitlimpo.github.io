---
import type { LandingVariant } from "../data/landing";
import { contact, shared, variants } from "../data/landing";

type Props = {
  variant: LandingVariant;
};

const { variant } = Astro.props;
const content = variants[variant];
const isPremium = variant === "premium";
---

<section id="video" class:list={["section-anchor relative overflow-hidden", isPremium ? "mesh-premium" : "mesh-popular"]}>
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent"></div>
  <div class="mx-auto grid min-h-[calc(100svh-76px)] max-w-7xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8 lg:py-20">
    <div>
      <div class="mb-6 inline-flex max-w-full items-center gap-3 rounded-full border border-primary/40 bg-panel/70 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.2em] text-primary shadow-soft backdrop-blur">
        <span class="size-2 rounded-full bg-accent"></span>
        <span class="truncate">{content.eyebrow}</span>
      </div>

      <h1 class="max-w-4xl text-balance font-display text-4xl font-black leading-[0.96] tracking-[-0.05em] text-ink sm:text-6xl lg:text-7xl">
        {content.heroTitle}
      </h1>

      <p class="mt-6 max-w-2xl text-pretty text-lg font-medium leading-8 text-muted sm:text-xl">
        {content.heroLead}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={contact.whatsappHref}
          class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-4 text-base font-extrabold text-slate-950 shadow-lift transition-colors duration-200 hover:bg-accent-strong focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        >
          {content.primaryCta}
        </a>
        <a
          href={contact.phoneHref}
          class="inline-flex items-center justify-center rounded-full border border-border bg-panel/60 px-7 py-4 text-base font-extrabold text-ink transition-colors duration-200 hover:border-primary hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        >
          Ligar {contact.phoneDisplay}
        </a>
      </div>

      <dl class="mt-10 grid gap-3 sm:grid-cols-3">
        {content.proof.map((item) => (
          <div class="rounded-3xl border border-border bg-panel/58 p-4 shadow-soft backdrop-blur">
            <dt class="text-sm font-extrabold text-ink">{item}</dt>
            <dd class="mt-1 text-xs font-bold uppercase tracking-[0.16em] text-muted">{shared.area}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="relative">
      <div class="absolute -inset-5 rounded-[2.5rem] border border-primary/30 bg-primary/20 blur-2xl"></div>
      <div class="relative overflow-hidden rounded-[2rem] border border-primary/30 bg-panel shadow-soft">
        <div class="flex items-center justify-between gap-4 border-b border-border bg-panel-strong px-5 py-4">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary">Vídeo do processo</p>
            <h2 class="mt-1 font-display text-xl font-black tracking-tight text-ink">Assista à limpeza Jet Split</h2>
          </div>
          <span class="rounded-full bg-primary px-3 py-2 text-xs font-extrabold text-slate-950">Play</span>
        </div>
        <div class="aspect-video w-full bg-black">
          <iframe
            class="size-full"
            src={shared.youtubeEmbedUrl}
            title="Vídeo demonstrativo da limpeza Jet Split da Split Limpo"
            loading="eager"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
        <div class="grid gap-4 border-t border-border p-5 sm:grid-cols-3 sm:p-6">
          <div>
            <p class="text-3xl font-black text-primary">{shared.rating}</p>
            <p class="mt-1 text-xs font-extrabold uppercase tracking-[0.16em] text-muted">estrelas no Google</p>
          </div>
          <div>
            <p class="text-3xl font-black text-primary">{shared.reviewCount}</p>
            <p class="mt-1 text-xs font-extrabold uppercase tracking-[0.16em] text-muted">avaliações</p>
          </div>
          <div>
            <p class="text-3xl font-black text-primary">Manaus</p>
            <p class="mt-1 text-xs font-extrabold uppercase tracking-[0.16em] text-muted">atendimento local</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
