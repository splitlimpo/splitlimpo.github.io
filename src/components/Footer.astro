---
import { contact, shared } from "../data/landing";
---

<footer class="border-t border-border bg-page py-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 text-sm font-semibold text-muted sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <div>
      <p class="font-display text-lg font-black text-ink">{shared.brand}</p>
      <p class="mt-1">Limpeza e higienização de ar-condicionado split.</p>
    </div>
    <div class="flex flex-col gap-2 md:items-end">
      <a class="transition-colors duration-200 hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent" href={contact.phoneHref}>{contact.phoneDisplay}</a>
      <a class="transition-colors duration-200 hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent" href={contact.whatsappHref}>Atendimento por WhatsApp</a>
    </div>
  </div>
</footer>
