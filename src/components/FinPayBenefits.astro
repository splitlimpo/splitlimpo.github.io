---
import comfortIcon from "../../assets/svgs/Mais Conforto no Uso.svg";
import deepCleaningIcon from "../../assets/svgs/SplitLimpo Deep Cleaning.svg";
import disassemblyIcon from "../../assets/svgs/SplitLimpo Desmontagem.svg";
import { variants } from "../data/landing";

const benefitIcons = [deepCleaningIcon, disassemblyIcon, comfortIcon];
const benefits = variants.finpay.benefits.map((benefit, index) => ({
  ...benefit,
  icon: benefitIcons[index],
}));
---

<section id="beneficios" class="section-anchor relative z-10 -mt-16 bg-[#f8fbfc] pb-20 pt-0 sm:-mt-24 sm:pb-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-[1.75rem] border border-border bg-panel p-8 shadow-soft sm:p-10 lg:p-12">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-primary">Padrão Split Limpo</p>
          <h2 class="mt-4 max-w-md text-balance font-display text-3xl font-black leading-tight tracking-[-0.04em] text-ink sm:text-4xl">
            Uma limpeza pensada para preservar o aparelho e o ambiente.
          </h2>
        </div>
        <p class="max-w-md text-base font-semibold leading-7 text-muted lg:justify-self-end">
          O atendimento combina proteção do ambiente, técnica de higienização profunda e resultado visível sem retirar o aparelho da parede.
        </p>
      </div>

      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {benefits.map((benefit) => (
          <article>
            <img
              src={benefit.icon.src}
              width={benefit.icon.width}
              height={benefit.icon.height}
              alt=""
              loading="lazy"
              class="mb-6 size-16 select-none"
            />
            <h3 class="font-display text-lg font-black tracking-tight text-ink">{benefit.title}</h3>
            <p class="mt-3 max-w-xs text-sm font-semibold leading-6 text-muted">{benefit.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
