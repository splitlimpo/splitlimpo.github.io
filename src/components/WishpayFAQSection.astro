---
import { shared } from "../data/landing";
---

<section id="faq" class="section-anchor bg-page py-20 sm:py-24" aria-labelledby="wishpay-faq-title">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-primary">FAQ</p>
      <h2 id="wishpay-faq-title" class="mt-4 text-balance font-display text-3xl font-black tracking-[-0.04em] text-ink sm:text-5xl">
        Perguntas frequentes
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base font-semibold leading-7 text-muted">
        Inspirado no formato da Wishpay: compacto, direto e fácil de escanear.
      </p>
    </div>

    <div class="mt-10 space-y-3">
      {shared.faqs.map((item) => (
        <details class="group rounded-2xl border border-border bg-panel p-5 shadow-lift">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-base font-black tracking-tight text-ink focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary">
            {item.question}
            <span class="grid size-8 shrink-0 place-items-center rounded-full bg-page-soft text-primary transition-transform duration-200 group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-sm font-semibold leading-7 text-muted">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
